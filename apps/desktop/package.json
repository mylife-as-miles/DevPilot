{
  "name": "@devpilot/desktop",
  "version": "0.1.4",
  "description": "DevPilot local-first autonomous development workspace.",
  "author": "DevPilot",
  "private": true,
  "type": "module",
  "main": "main.cjs",
  "exports": {
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "electron .",
    "prepare:runtime": "node scripts/prepare-python-runtime.cjs",
    "package": "yarn prepare:runtime && electron-forge package",
    "make": "yarn prepare:runtime && electron-forge make",
    "verify": "node --check main.cjs && node --check preload.cjs && node --check conversation-preferences.cjs && node --test desktop-shell.test.cjs forge-config.test.cjs conversation-preferences.test.cjs"
  },
  "devDependencies": {
    "electron": "43.1.1"
  },
  "config": {
    "forge": "./forge.config.cjs"
  }
}
