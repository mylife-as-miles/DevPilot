{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DevPilot",
  "version": "0.2.7",
  "identifier": "com.devpilot.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "node ./scripts/runTauriBeforeCommand.mjs tauri:prepare:dev",
    "beforeBuildCommand": "node ./scripts/runTauriBeforeCommand.mjs tauri:prepare:build"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "capabilities": [
        "default",
        "pet_overlay"
      ],
      "csp": null
    },
    "windows": [
      {
        "title": "DevPilot",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#F5F5F5",
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "externalBin": [
      "binaries/hsetup"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
