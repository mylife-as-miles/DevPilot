{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DevPilot (dev)",
  "identifier": "com.devpilot.desktop.dev",
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default",
        "pet_overlay"
      ]
    },
    "windows": [
      {
        "title": "DevPilot (dev)",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#F5F5F5",
        "dragDropEnabled": false,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
