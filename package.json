{
  "name": "devpilot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "DevPilot desktop client",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "node scripts/dev-desktop.mjs",
    "desktop:dev": "node scripts/dev-desktop.mjs",
    "desktop:build": "node scripts/build-desktop.mjs",
    "electron:dev": "node scripts/electron-desktop.mjs dev",
    "electron:build": "node scripts/electron-desktop.mjs build",
    "electron:verify": "yarn --cwd apps/desktop verify",
    "desktop:test": "yarn test:unit",
    "desktop:typecheck": "yarn typecheck",
    "ui": "yarn workspace @happier-dev/app start",
    "ui:web": "yarn workspace @happier-dev/app web",
    "ui:electron": "yarn electron:dev",
    "build:packages": "yarn workspace @happier-dev/protocol build && yarn workspace @happier-dev/transfers build && yarn workspace @happier-dev/agents build && yarn workspace @happier-dev/release-runtime build && yarn workspace @happier-dev/cli-common build && yarn workspace @happier-dev/connection-supervisor build",
    "test": "yarn test:unit",
    "test:unit": "yarn workspace @happier-dev/protocol test && yarn workspace @happier-dev/transfers test && yarn workspace @happier-dev/agents test && yarn workspace @happier-dev/cli-common test && yarn workspace @happier-dev/connection-supervisor test && yarn workspace @happier-dev/bootstrap test && yarn workspace @happier-dev/app test:unit",
    "typecheck": "yarn workspace @happier-dev/protocol typecheck && yarn workspace @happier-dev/transfers typecheck && yarn workspace @happier-dev/agents typecheck && yarn workspace @happier-dev/cli-common typecheck && yarn workspace @happier-dev/connection-supervisor typecheck && yarn workspace @happier-dev/bootstrap typecheck && yarn workspace @happier-dev/app typecheck",
    "import:happier": "node scripts/import-happier-desktop.mjs",
    "import:happier:dry": "node scripts/import-happier-desktop.mjs --dry-run",
    "test:importer": "node --test scripts/import-happier-desktop.test.mjs",
    "test:desktop-command": "node --test scripts/desktop-command.test.mjs",
    "test:branding": "node --experimental-strip-types --test packages/branding/src/brand.test.ts",
    "test:runtime-discovery": "node --experimental-strip-types --test packages/devpilot-runtime/src/runtimeDiscovery.test.ts packages/devpilot-runtime/src/runtimeProbe.test.ts packages/devpilot-runtime/src/acpProcessClient.test.cjs",
    "test:research": "node --experimental-strip-types --test packages/devpilot-research/src/*.test.ts"
  },
  "workspaces": {
    "packages": [
      "apps/bootstrap",
      "apps/ui",
      "apps/cli",
      "apps/stack",
      "apps/desktop",
      "packages/branding",
      "packages/devpilot-runtime",
      "packages/devpilot-research",
      "packages/agents",
      "packages/audio-stream-native",
      "packages/cli-common",
      "packages/connection-supervisor",
      "packages/protocol",
      "packages/release-runtime",
      "packages/sherpa-native",
      "packages/transfers"
    ],
    "nohoist": [
      "**/zod",
      "**/react",
      "**/react-dom",
      "**/react-native",
      "**/react-native/**",
      "**/react-native-edge-to-edge/**",
      "**/react-native-incall-manager/**"
    ]
  },
  "resolutions": {
    "@tauri-apps/api": "2.8.0",
    "basic-ftp": "5.2.0",
    "@elevenlabs/client": "1.3.1",
    "@elevenlabs/react": "1.2.1",
    "@elevenlabs/react-native": "1.1.3",
    "livekit-client": "2.18.7",
    "tar": "7.5.13",
    "vite@^5.0.0 || ^6.0.0 || ^7.0.0-0": "7.3.2",
    "vitest/vite": "7.3.2",
    "vite-node/vite": "7.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@sentry/cli": "^3.2.2",
    "electron": "43.1.1",
    "vite": "7.3.2"
  },
  "packageManager": "yarn@1.22.22"
}
